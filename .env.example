# YouTube Data API v3 key
# Get yours at: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your Google Cloud project
YOUTUBE_API_KEY=your_api_key_here

# YouTube channel handle (without @)
YOUTUBE_CHANNEL_HANDLE=laslocurasdemiguelin4300

# Optional for static deployments:
# exposed to the browser so the homepage can refresh YouTube data
# after the site is built. Restrict this key by HTTP referrer first.
PUBLIC_YOUTUBE_API_KEY=your_browser_restricted_api_key_here
PUBLIC_YOUTUBE_CHANNEL_ID=your_channel_id_here
