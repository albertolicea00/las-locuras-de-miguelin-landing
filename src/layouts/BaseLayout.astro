---
import type { Locale } from "../i18n/utils";
import { useTranslations, getLocalizedPath, getAlternateLang, LOCALES } from "../i18n/utils";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  lang: Locale;
}

const { title, description, lang } = Astro.props;
const t = useTranslations(lang);
const altLang = getAlternateLang(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Navbar lang={lang} />
    <slot />
    
    <!-- Floating Sponsor Button -->
    {!Astro.url.pathname.includes('/patrocinar') && !Astro.url.pathname.includes('/sponsor') && (
      <a 
        href={getLocalizedPath("/patrocinar", lang)} 
        class="fixed bottom-8 right-8 z-[60] rounded-full bg-neon-purple px-5 py-3 text-sm font-semibold text-white shadow-[0_14px_35px_rgba(224,64,251,0.35)] transition hover:scale-105 hover:bg-neon-purple/90"
      >
        {lang === 'es' ? 'Patrocinar' : 'Sponsor'}
      </a>
    )}

    <Footer lang={lang} />
  </body>
</html>
