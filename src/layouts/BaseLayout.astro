---
import type { Locale } from "../i18n/utils";
import { useTranslations, getLocalizedPath, getAlternateLang, LOCALES } from "../i18n/utils";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  lang: Locale;
}

const { title, description, lang } = Astro.props;
const t = useTranslations(lang);
const altLang = getAlternateLang(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Navbar lang={lang} />
    <slot />
    
    <!-- Floating Sponsor Button -->
    {!Astro.url.pathname.includes('/patrocinar') && !Astro.url.pathname.includes('/sponsor') && (
      <a 
        href={getLocalizedPath("/patrocinar", lang)} 
        class="fixed bottom-10 right-10 z-[60] group"
      >
        <div class="absolute inset-0 bg-accent rounded-full blur-xl group-hover:blur-2xl transition-all animate-pulse opacity-50"></div>
        <div class="relative bg-accent text-dark font-black px-6 py-6 rounded-full flex flex-col items-center justify-center leading-none text-center shadow-[0_0_40px_rgba(255,214,0,0.4)] border-4 border-dark group-hover:scale-110 transition-transform duration-300">
          <span class="text-xs uppercase tracking-tighter mb-1">{lang === 'es' ? 'TU MARCA' : 'YOUR BRAND'}</span>
          <span class="text-xl">{lang === 'es' ? 'PATROCINAR' : 'SPONSOR'}</span>
          <div class="absolute -top-2 -right-2 bg-primary text-white text-[10px] px-2 py-1 rounded-full animate-bounce">
            HOT 🔥
          </div>
        </div>
      </a>
    )}

    <Footer lang={lang} />
  </body>
</html>
