---
import BaseLayout from "../layouts/BaseLayout.astro";
import { useTranslations } from "../i18n/utils";
import { SHOW_SOCIALS } from "../data/social";

const lang = "es" as const;
const t = useTranslations(lang);
---

<BaseLayout title={`Patrocinar | ${t.meta.title}`} description="Patrocina Las Locuras de Miguelín y llega a millones de personas" lang={lang}>
  
  <!-- Hero -->
  <section class="min-h-[60vh] flex items-center relative overflow-hidden pt-24">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-20 left-10 w-96 h-96 bg-accent/10 rounded-full blur-3xl animate-float"></div>
      <div class="absolute bottom-20 right-10 w-72 h-72 bg-primary/10 rounded-full blur-3xl animate-float" style="animation-delay: 1.5s;"></div>
      <div class="absolute top-1/2 left-1/3 w-64 h-64 bg-neon-purple/10 rounded-full blur-3xl animate-float" style="animation-delay: 2.5s;"></div>
    </div>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 relative z-10 text-center">
      <div class="inline-block px-4 py-1 bg-accent/20 border border-accent/30 rounded-full text-accent text-sm font-bold mb-6 animate-pulse">
        🤝 PARTNERS & SPONSORS
      </div>
      <h1 class="font-display text-5xl md:text-7xl lg:text-8xl text-white leading-[0.9] mb-6">{t.sponsorPage.heroTitle}</h1>
      <p class="text-white/50 text-xl max-w-2xl mx-auto">{t.sponsorPage.heroSubtitle}</p>
      
      <!-- Stats Row -->
      <div class="flex flex-wrap justify-center gap-6 mt-12">
        <div class="bg-white/5 border border-white/10 rounded-2xl px-8 py-5 text-center">
          <div class="flex items-center justify-center gap-2 mb-1">
            <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            <span class="text-white/40 text-xs uppercase font-bold">YouTube</span>
          </div>
          <span class="text-white font-display text-3xl">{SHOW_SOCIALS.stats.youtube}</span>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl px-8 py-5 text-center">
          <div class="flex items-center justify-center gap-2 mb-1">
            <svg class="w-5 h-5 text-pink-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
            <span class="text-white/40 text-xs uppercase font-bold">Instagram</span>
          </div>
          <span class="text-white font-display text-3xl">{SHOW_SOCIALS.stats.instagram}</span>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl px-8 py-5 text-center">
          <div class="flex items-center justify-center gap-2 mb-1">
            <svg class="w-5 h-5 text-blue-500" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            <span class="text-white/40 text-xs uppercase font-bold">Facebook</span>
          </div>
          <span class="text-white font-display text-3xl">{SHOW_SOCIALS.stats.facebook}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Us Stories -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-4xl md:text-5xl text-white text-center mb-16">{t.sponsorPage.storyTitle}</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-secondary rounded-2xl p-8 border border-white/5 hover:border-primary/30 transition-all duration-300 hover:-translate-y-2 group">
          <div class="w-16 h-16 bg-primary/20 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-primary/40 transition">
            <span class="text-3xl">🎙</span>
          </div>
          <p class="text-white/70 text-lg leading-relaxed">{t.sponsorPage.story1}</p>
        </div>
        <div class="bg-secondary rounded-2xl p-8 border border-white/5 hover:border-accent/30 transition-all duration-300 hover:-translate-y-2 group">
          <div class="w-16 h-16 bg-accent/20 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-accent/40 transition">
            <span class="text-3xl">🔥</span>
          </div>
          <p class="text-white/70 text-lg leading-relaxed">{t.sponsorPage.story2}</p>
        </div>
        <div class="bg-secondary rounded-2xl p-8 border border-white/5 hover:border-neon-purple/30 transition-all duration-300 hover:-translate-y-2 group">
          <div class="w-16 h-16 bg-neon-purple/20 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-neon-purple/40 transition">
            <span class="text-3xl">📈</span>
          </div>
          <p class="text-white/70 text-lg leading-relaxed">{t.sponsorPage.story3}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Plans -->
  <section class="py-20 bg-secondary/30">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-accent font-medium text-sm tracking-widest uppercase">Plans</span>
        <h2 class="font-display text-4xl md:text-5xl text-white mt-2">{t.sponsorPage.plansTitle}</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Plan 1: Basic -->
        <div class="bg-secondary rounded-3xl p-8 border border-white/10 hover:border-white/20 transition-all duration-300 hover:-translate-y-2 flex flex-col">
          <div class="text-center mb-8">
            <div class="inline-block bg-white/5 rounded-full px-4 py-1 text-xs font-bold text-white/50 uppercase tracking-widest mb-4">Starter</div>
            <h3 class="font-display text-2xl text-white">{t.sponsorPage.plan1}</h3>
          </div>
          <ul class="space-y-4 text-white/50 text-sm flex-1">
            <li class="flex items-start gap-3"><span class="text-primary mt-0.5">✓</span> Mención durante el episodio</li>
            <li class="flex items-start gap-3"><span class="text-primary mt-0.5">✓</span> Logo en la descripción del video</li>
            <li class="flex items-start gap-3"><span class="text-primary mt-0.5">✓</span> Etiqueta en redes sociales</li>
          </ul>
          <a href="#sponsor-form" class="mt-8 block text-center bg-white/5 hover:bg-white/10 border border-white/10 text-white font-semibold px-6 py-4 rounded-xl transition">
            Más info →
          </a>
        </div>
        <!-- Plan 2: Viral -->
        <div class="bg-gradient-to-b from-primary/10 to-secondary rounded-3xl p-8 border-2 border-primary/40 hover:border-primary transition-all duration-300 hover:-translate-y-3 flex flex-col relative">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-lg shadow-primary/40">
            🔥 POPULAR
          </div>
          <div class="text-center mb-8">
            <div class="inline-block bg-primary/20 rounded-full px-4 py-1 text-xs font-bold text-primary uppercase tracking-widest mb-4">Pro</div>
            <h3 class="font-display text-2xl text-white">{t.sponsorPage.plan2}</h3>
          </div>
          <ul class="space-y-4 text-white/60 text-sm flex-1">
            <li class="flex items-start gap-3"><span class="text-primary mt-0.5">✓</span> Todo lo del plan Básico</li>
            <li class="flex items-start gap-3"><span class="text-primary mt-0.5">✓</span> Segmento dedicado en el show</li>
            <li class="flex items-start gap-3"><span class="text-primary mt-0.5">✓</span> Post en Instagram + Story</li>
            <li class="flex items-start gap-3"><span class="text-primary mt-0.5">✓</span> Clip viral en TikTok/Reels</li>
          </ul>
          <a href="#sponsor-form" class="mt-8 block text-center bg-primary hover:bg-primary/80 text-white font-bold px-6 py-4 rounded-xl transition neon-glow">
            Más info →
          </a>
        </div>
        <!-- Plan 3: Elite -->
        <div class="bg-secondary rounded-3xl p-8 border border-accent/20 hover:border-accent/50 transition-all duration-300 hover:-translate-y-2 flex flex-col">
          <div class="text-center mb-8">
            <div class="inline-block bg-accent/20 rounded-full px-4 py-1 text-xs font-bold text-accent uppercase tracking-widest mb-4">VIP</div>
            <h3 class="font-display text-2xl text-white">{t.sponsorPage.plan3}</h3>
          </div>
          <ul class="space-y-4 text-white/50 text-sm flex-1">
            <li class="flex items-start gap-3"><span class="text-accent mt-0.5">✓</span> Todo lo del plan Viral</li>
            <li class="flex items-start gap-3"><span class="text-accent mt-0.5">✓</span> Patrocinio oficial del show</li>
            <li class="flex items-start gap-3"><span class="text-accent mt-0.5">✓</span> Tu producto físicamente en el set</li>
            <li class="flex items-start gap-3"><span class="text-accent mt-0.5">✓</span> Presencia en eventos en vivo</li>
            <li class="flex items-start gap-3"><span class="text-accent mt-0.5">✓</span> Acceso al crew para colaboraciones</li>
          </ul>
          <a href="#sponsor-form" class="mt-8 block text-center bg-accent/10 hover:bg-accent/20 border border-accent/30 text-accent font-semibold px-6 py-4 rounded-xl transition">
            Más info →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section id="sponsor-form" class="py-20">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-display text-4xl md:text-5xl text-white">{t.sponsorPage.formTitle}</h2>
        <p class="text-white/40 text-lg mt-4">{t.sponsorPage.formSubtitle}</p>
      </div>
      <form class="bg-secondary rounded-3xl border border-white/10 p-8 md:p-10 space-y-6">
        <div>
          <label class="text-white/50 text-sm font-medium mb-2 block">{t.sponsorPage.formName}</label>
          <input type="text" placeholder="Miami Coffee Co." class="w-full bg-white/5 border border-white/10 focus:border-primary/50 rounded-xl px-5 py-4 text-white placeholder:text-white/20 outline-none transition" />
        </div>
        <div>
          <label class="text-white/50 text-sm font-medium mb-2 block">{t.sponsorPage.formEmail}</label>
          <input type="email" placeholder="marketing@tusitio.com" class="w-full bg-white/5 border border-white/10 focus:border-primary/50 rounded-xl px-5 py-4 text-white placeholder:text-white/20 outline-none transition" />
        </div>
        <div>
          <label class="text-white/50 text-sm font-medium mb-2 block">{t.sponsorPage.formMessage}</label>
          <textarea rows="4" placeholder={t.sponsorPage.formMessage} class="w-full bg-white/5 border border-white/10 focus:border-primary/50 rounded-xl px-5 py-4 text-white placeholder:text-white/20 outline-none transition resize-none"></textarea>
        </div>
        <button type="submit" class="w-full bg-primary hover:bg-primary/80 text-white font-bold text-lg px-8 py-5 rounded-xl transition neon-glow">
          {t.sponsorPage.formSubmit}
        </button>
      </form>
    </div>
  </section>

</BaseLayout>
