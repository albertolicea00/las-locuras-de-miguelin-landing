---
import type { Locale } from "../i18n/utils";
import { useTranslations, getLocalizedPath } from "../i18n/utils";
import { SHOW_SOCIALS } from "../data/social";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const homePath = getLocalizedPath("/", lang);
---

<footer class="footer-gradient py-12 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-3 gap-8 items-center">
      <div>
        <a href={homePath} class="flex items-center gap-2">
          <span class="font-display text-2xl text-primary">LAS LOCURAS</span>
          <span class="font-display text-2xl text-white">DE MIGUELÍN</span>
        </a>
        <p class="text-white/40 text-sm mt-2">{t.footer.tagline}</p>
      </div>
      <div class="text-center">
        <div class="flex justify-center gap-6 text-sm text-white/50">
          <a href={`${homePath}#episodios`} class="hover:text-primary transition">{t.nav.episodes}</a>
          <a href={getLocalizedPath("/personajes", lang)} class="hover:text-primary transition">{t.nav.crew}</a>
          <a href={`${homePath}#eventos`} class="hover:text-primary transition">{t.nav.events}</a>
          <a href={`${homePath}#partners`} class="hover:text-primary transition">{t.nav.merch}</a>
        </div>
      </div>
      <div class="text-right">
        <div class="flex justify-end gap-4">
          <a href={SHOW_SOCIALS.youtube} target="_blank" rel="noopener noreferrer" class="text-white/30 hover:text-primary transition">YouTube</a>
          <a href={SHOW_SOCIALS.instagram} target="_blank" rel="noopener noreferrer" class="text-white/30 hover:text-primary transition">Instagram</a>
          <a href={SHOW_SOCIALS.facebook} target="_blank" rel="noopener noreferrer" class="text-white/30 hover:text-primary transition">Facebook</a>
        </div>
        <p class="text-white/20 text-xs mt-2">&copy; 2026 Las Locuras de Miguelín</p>
      </div>
    </div>
  </div>
</footer>
