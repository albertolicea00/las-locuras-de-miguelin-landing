---
import type { Locale } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";
import { getSiteData } from "../data/site";
import type { YouTubeVideo } from "../services/youtube";

interface Props {
  lang: Locale;
  liveVideo?: YouTubeVideo | null;
}

const { lang, liveVideo } = Astro.props;
const t = useTranslations(lang);
const data = getSiteData(lang);
const fallback = data.latestEpisode;

// Use live YouTube data if available, otherwise fallback
const hasLive = !!liveVideo;
const title = hasLive ? liveVideo!.title : `EP ${fallback.number} — ${fallback.title}`;
const thumbnail = hasLive ? liveVideo!.thumbnailHigh : fallback.thumbnail;
const duration = hasLive ? liveVideo!.duration : fallback.duration;
const views = hasLive ? liveVideo!.viewCount : "";
const videoUrl = hasLive ? `https://www.youtube.com/watch?v=${liveVideo!.id}` : "#";
const embedUrl = hasLive ? liveVideo!.embedUrl : "";
---

<section id="ultimo-episodio" class="py-20 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="text-primary font-medium text-sm tracking-widest uppercase">{t.sections.latestEpisodeLabel}</span>
      <h2 class="section-title text-white mt-2">{t.sections.latestEpisode}</h2>
    </div>
    <div class="max-w-4xl mx-auto">
      {hasLive ? (
        <!-- Real YouTube Embed -->
        <div class="relative rounded-2xl overflow-hidden neon-border aspect-video bg-secondary">
          <iframe
            src={`${embedUrl}?rel=0`}
            title={title}
            class="w-full h-full"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        </div>
      ) : (
        <!-- Fallback static thumbnail -->
        <div class="relative rounded-2xl overflow-hidden neon-border aspect-video bg-secondary">
          <img src={thumbnail} alt={title} class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-black/40 flex items-center justify-center group cursor-pointer hover:bg-black/20 transition">
            <div class="w-20 h-20 bg-primary rounded-full flex items-center justify-center group-hover:scale-110 transition neon-glow">
              <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
        </div>
      )}
      <div class="mt-6 flex flex-wrap items-center justify-between gap-4">
        <div>
          <h3 class="text-2xl font-bold text-white">{title}</h3>
          <div class="flex gap-4 mt-2 text-white/50 text-sm">
            {duration && <span>⏱ {duration}</span>}
            {views && <span>👁 {views} {t.characterPage.views}</span>}
            {!hasLive && <span>🎤 {fallback.guest}</span>}
            {!hasLive && <span>💬 {fallback.topic}</span>}
          </div>
        </div>
        <a href={videoUrl} target="_blank" rel="noopener noreferrer" class="bg-primary/20 hover:bg-primary text-primary hover:text-white border border-primary/30 px-6 py-3 rounded-xl font-medium transition">
          {t.actions.watchOnYoutube}
        </a>
      </div>
    </div>
  </div>
</section>
