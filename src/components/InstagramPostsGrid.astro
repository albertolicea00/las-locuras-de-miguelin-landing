---
import type { Locale } from "../i18n/utils";
import type { InstagramPost } from "../services/instagram";

interface Props {
  lang: Locale;
  posts: InstagramPost[];
  instagramUrl: string;
  characterName: string;
  characterColor: string;
}

const { lang, posts, instagramUrl, characterName, characterColor } = Astro.props;

function formatNumber(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + "M";
  if (n >= 1_000) return (n / 1_000).toFixed(1) + "K";
  return n.toString();
}

function timeAgo(timestamp: number, locale: Locale): string {
  const seconds = Math.floor(Date.now() / 1000 - timestamp);
  const days = Math.floor(seconds / 86400);
  if (days > 30) {
    const months = Math.floor(days / 30);
    return locale === "es" ? `hace ${months}m` : `${months}mo ago`;
  }
  if (days > 0) return locale === "es" ? `hace ${days}d` : `${days}d ago`;
  const hours = Math.floor(seconds / 3600);
  if (hours > 0) return locale === "es" ? `hace ${hours}h` : `${hours}h ago`;
  return locale === "es" ? "ahora" : "now";
}

const displayPosts = posts.slice(0, 9);
---

{displayPosts.length >= 0 && (
  <section class="py-16" id="instagram-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-3">
          <svg class="w-6 h-6 text-pink-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          <h2 class="font-display text-3xl text-white">
            {lang === "es" ? "ÚLTIMAS PUBLICACIONES" : "LATEST POSTS"}
          </h2>
        </div>
        <a
          href={instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium px-4 py-2 rounded-lg border transition hidden sm:inline-flex items-center gap-2"
          style={`color:${characterColor}; border-color:${characterColor}40`}
        >
          {lang === "es" ? "Ver en Instagram" : "View on Instagram"}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-3 gap-3 md:gap-4" id="instagram-posts-grid">
        {displayPosts.map((post) => (
          <a
            href={post.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative aspect-square rounded-xl overflow-hidden bg-secondary border border-white/5 hover:border-white/20 transition-all duration-300"
          >
            <img
              src={post.thumbnail}
              alt={post.caption.slice(0, 60)}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            {post.isVideo && (
              <div class="absolute top-2 right-2 bg-black/60 backdrop-blur-sm rounded-full p-1.5">
                <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-3">
              <div class="flex items-center gap-3 text-white text-xs">
                <span class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                  {formatNumber(post.likes)}
                </span>
                <span class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                  {formatNumber(post.comments)}
                </span>
              </div>
              {post.caption && (
                <p class="text-white/70 text-[10px] mt-1.5 line-clamp-2 leading-tight">{post.caption.slice(0, 100)}</p>
              )}
              <p class="text-white/40 text-[10px] mt-1">{timeAgo(post.timestamp, lang)}</p>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-6 sm:hidden">
        <a
          href={instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium px-5 py-2.5 rounded-xl border transition"
          style={`color:${characterColor}; border-color:${characterColor}40`}
        >
          {lang === "es" ? "Ver en Instagram" : "View on Instagram"}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>

      {displayPosts.length === 0 && (
        <div id="ig-loading-placeholder" class="py-12 text-center">
          <div class="inline-block w-8 h-8 border-4 border-pink-500/30 border-t-pink-500 rounded-full animate-spin mb-4"></div>
          <p class="text-white/40 text-sm">{lang === "es" ? "Cargando publicaciones..." : "Loading posts..."}</p>
        </div>
      )}
    </div>
  </section>
)}

<script>
  // This helps identify if we need to show/hide the whole section
  const section = document.getElementById("instagram-section");
  const grid = document.getElementById("instagram-posts-grid");
  const placeholder = document.getElementById("ig-loading-placeholder");
  
  if (grid && grid.children.length === 0 && !placeholder) {
    if (section) section.style.display = 'none';
  }
</script>
